{
  "name": "pi-requesty-discover",
  "version": "1.0.3",
  "description": "Discover available Requesty models for the Pi Coding Agent",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enolive/pi-requesty-discover.git"
  },
  "homepage": "https://github.com/enolive/pi-requesty-discover",
  "bugs": {
    "url": "https://github.com/enolive/pi-requesty-discover/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extensions",
    "requesty",
    "openai-compatible",
    "models"
  ],
  "scripts": {
    "agent-lint": "agnix . -v",
    "format:check": "prettier --check src test",
    "format": "prettier --write src test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "release": "npm version patch && git push --follow-tags",
    "test": "vitest run",
    "test:unit": "vitest run src",
    "test:unit:coverage": "vitest run src --coverage",
    "test:integration": "vitest run test/integration.test.ts",
    "test:watch": "vitest",
    "prepack": "downdoc README.adoc"
  },
  "license": "MIT",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "devDependencies": {
    "@earendil-works/pi-tui": "^0.80.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "agnix": "^0.37.0",
    "downdoc": "^1.1.0-stable",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "msw": "^2.14.6",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
